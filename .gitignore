!backend/storage/chroma/.gitkeep
backend/logs/

# IDE
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Alembic — keep the migration env, ignore generated revision files
backend/alembic/versions/*.py
!backend/alembic/versions/.gitkeep
