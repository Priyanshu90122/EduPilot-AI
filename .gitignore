# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
*.db
edupilot.db
test.db

# Env (never commit real secrets — .env.example / .env.docker.example ARE tracked)
backend/.env
frontend/.env
*.env.local

# Node
node_modules/
dist/
dist-ssr/
