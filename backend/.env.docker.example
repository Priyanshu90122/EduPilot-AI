# ── Docker Compose profile (Postgres + Redis + Celery) ─────────────────────
# Use this instead of .env.example when running `docker compose up`:
#
#   cp backend/.env.docker.example backend/.env
#
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-string

DATABASE_URL=postgresql+asyncpg://edupilot:edupilot_pass@db:5432/edupilot_db

USE_CELERY=true
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

AI_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

CHROMA_PERSIST_DIR=/app/storage/chroma
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=25

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# used by docker-compose.yml directly for the db container
POSTGRES_USER=edupilot
POSTGRES_PASSWORD=edupilot_pass
POSTGRES_DB=edupilot_db
