# ── Local dev defaults (no Docker, no Postgres, no Redis needed) ──────────
# Every value below already has a working default in app/core/config.py.
# Copy this file to `.env` and you only NEED to set an AI API key to run:
#
#   cp .env.example .env
#
# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-string-for-anything-beyond-local-testing

# Database — SQLite file, created automatically on first run. No setup needed.
# For Postgres (e.g. production or Docker), use:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/edupilot_db
DATABASE_URL=sqlite+aiosqlite:///./edupilot.db

# Background jobs — false = documents are processed in-process (no Redis/Celery
# needed). Set to true only if you're running `celery -A app.celery_app worker`.
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI — REQUIRED: set one of these and matching AI_PROVIDER
AI_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=
# neeche wali 2 lines Gemini use karte waqt ignore hoti hain, hata bhi sakta hai
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Vector store + file storage — relative paths, created automatically
CHROMA_PERSIST_DIR=./storage/chroma
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=25

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
